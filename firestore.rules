rules_version = '3';

// Quiniela Mundial 2026 — Firestore security rules.
//
// Security boundaries enforced here:
//   - config/* and results/* : public read, admin-only write.
//   - users/{uid}            : a user reads/writes only their own doc (but cannot
//                              change their own paymentStatus); admin reads/writes all.
//   - predictions/{predId}   : a user reads/writes only their own entries, only while
//                              that league's window is open, and cannot self-mark paid;
//                              admin reads all and manages paymentStatus.
//   - pools/{poolId}         : signed-in read; writes only by admin/cron (admin SDK).
//   - tickets/{ticketId}     : a user reads only their own tickets and may create a
//                              PENDING ticket with no pool/team (cannot self-assign a
//                              team or mark paid). Updates are admin/cron only; the
//                              owner may delete only an unpaid, un-pooled ticket.
//
// NOTE (client-enforced, not security boundaries): the "max 5 pending" cap and the
// payment-deadline auto-void. These are courtesy/business rules; a Cloud Function can
// harden them later. config/app MUST be seeded for these get()s to resolve.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isAdmin()    { return isSignedIn() && request.auth.token.admin == true; }

    function cfg()      { return get(/databases/$(database)/documents/config/app).data; }
    function lockDate() { return cfg().lockDate; }
    function r32Start() { return cfg().r32StartDate; }
    function r16Start() { return cfg().r16StartDate; }

    match /config/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /results/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public, aggregate-only stats (paid counts → live bote). No personal data.
    // World-readable so the home page can show the growing prize; admin-only write.
    match /stats/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{uid} {
      allow read:   if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isAdmin()
                    || (isSignedIn() && request.auth.uid == uid
                        && request.resource.data.paymentStatus == resource.data.paymentStatus);
      allow delete: if isAdmin();
    }

    match /predictions/{predId} {
      function createWindowOpen() {
        let league = request.resource.data.league;
        return (league == 'main' && request.time < lockDate())
            || (league == 'r32'  && request.time < r32Start())
            || (league == 'r16'  && request.time < r16Start());
      }
      function updateWindowOpen() {
        let league = resource.data.league;
        return (league == 'main' && request.time < lockDate())
            || (league == 'r32'  && request.time < r32Start())
            || (league == 'r16'  && request.time < r16Start());
      }

      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);

      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.paymentStatus == 'pending'
                    && createWindowOpen();

      allow update: if isAdmin()
                    || (isSignedIn()
                        && resource.data.uid == request.auth.uid
                        && request.resource.data.uid == resource.data.uid
                        && request.resource.data.league == resource.data.league
                        && request.resource.data.paymentStatus == resource.data.paymentStatus
                        && updateWindowOpen());

      allow delete: if isAdmin()
                    || (isSignedIn() && resource.data.uid == request.auth.uid && updateWindowOpen());
    }

    // ─── Rifa de Países (modo tradicional) ──────────────────────────────────────
    // Pools are managed entirely by the cron (admin SDK, which bypasses rules).
    // Clients only read them to show the current pool's progress.
    match /pools/{poolId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // Tickets: a user buys a PENDING ticket for themselves with no pool/team. The
    // cron (admin SDK) bins paid tickets into pools and assigns the random team, so
    // the client can never set poolId/teamId/paymentStatus. Updates are admin-only.
    match /tickets/{ticketId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);

      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.paymentStatus == 'pending'
                    && request.resource.data.poolId == ''
                    && request.resource.data.teamId == '';

      allow update: if isAdmin();

      allow delete: if isAdmin()
                    || (isSignedIn()
                        && resource.data.uid == request.auth.uid
                        && resource.data.paymentStatus == 'pending'
                        && resource.data.poolId == '');
    }
  }
}
