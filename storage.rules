rules_version = '2';

// Firebase Storage — payment proof screenshots only.
//
//   payment-proofs/{uid}/{file} : the owner uploads their own image (auth.uid == uid);
//   the owner and admins can read it; only admins can delete. Writes are limited to
//   images ≤ 10 MB. (getDownloadURL tokens are how the admin opens a proof from the
//   report; these rules still gate listing and un-tokened access.)
service firebase.storage {
  match /b/{bucket}/o {
    match /payment-proofs/{uid}/{file=**} {
      allow read:   if request.auth != null
                    && (request.auth.uid == uid || request.auth.token.admin == true);
      allow write:  if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.size < 10 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
