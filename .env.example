# ─────────────────────────────────────────────────────────────────────────────
# Quiniela Mundial 2026 — environment variables
# Copy this file to ".env.local" and fill in the real values.
# All vars MUST be prefixed with VITE_ to be readable in the browser bundle.
# The Firebase web API key is an identifier (NOT a secret) — security is enforced
# by Firebase Auth + Firestore rules, so it is safe in the client bundle.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase web app config
# Firebase console > Project settings > General > Your apps > SDK setup and config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Form for payment / transfer confirmation
# BASE_URL  = the form's public ".../viewform" URL
# ENTRY_*   = the entry.XXXXXXX field IDs taken from the form's "pre-filled link"
# The same form is reused for Quiniela (random-team) tickets: the "Competencia" field
# gets the label "Quiniela" and PREDID receives the ticket folio (RIFA-XXXXX).
VITE_PAYMENT_FORM_BASE_URL=
VITE_PAYMENT_FORM_ENTRY_PREDID=
VITE_PAYMENT_FORM_ENTRY_EMAIL=
VITE_PAYMENT_FORM_ENTRY_LEAGUE=

# ─────────────────────────────────────────────────────────────────────────────
# SERVER-SIDE secrets — NOT bundled by Vite (no VITE_ prefix). Used only by the
# scripts in scripts/ and the GitHub Actions workflows. In production these live
# as GitHub repo "Settings → Secrets and variables → Actions", NOT in this file.
# Set them locally only if you want to run the cron scripts by hand.
# ─────────────────────────────────────────────────────────────────────────────

# Results sync (scripts/syncResults.mjs · .github/workflows/sync-results.yml)
# FOOTBALL_DATA_API_KEY=
# FIREBASE_SERVICE_ACCOUNT=   # the service-account JSON as a single-line string

# Rifa de Países pool manager (scripts/managePools.mjs · .github/workflows/manage-pools.yml)
# Emails are sent via Gmail SMTP — no domain needed, just a Google "App Password"
# (requires 2-Step Verification): https://myaccount.google.com/apppasswords
# GMAIL_USER=tu-correo@gmail.com
# GMAIL_APP_PASSWORD=         # 16-char app password (NOT your normal password)
# GMAIL_FROM_NAME=Pantera Mundialista   # optional display name
# APP_URL=https://tu-app.vercel.app    # optional — link shown in the assignment email
