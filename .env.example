# ─────────────────────────────────────────────────────────────────────────────
# Quiniela Mundial 2026 — environment variables
# Copy this file to ".env.local" and fill in the real values.
# All vars MUST be prefixed with VITE_ to be readable in the browser bundle.
# The Firebase web API key is an identifier (NOT a secret) — security is enforced
# by Firebase Auth + Firestore rules, so it is safe in the client bundle.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase web app config
# Firebase console > Project settings > General > Your apps > SDK setup and config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google Form for payment / transfer confirmation
# BASE_URL  = the form's public ".../viewform" URL
# ENTRY_*   = the entry.XXXXXXX field IDs taken from the form's "pre-filled link"
VITE_PAYMENT_FORM_BASE_URL=
VITE_PAYMENT_FORM_ENTRY_PREDID=
VITE_PAYMENT_FORM_ENTRY_EMAIL=
VITE_PAYMENT_FORM_ENTRY_LEAGUE=
